{
  "manifest_version": 3,
  "name": "HubSpot Filter Copier",
  "version": "1.0.0",
  "description": "Copy a shareable URL for the current HubSpot list view filters",

  "permissions": [
    "activeTab",
    "clipboardWrite"
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "HubSpot Filter Copier"
  },

  "content_scripts": [
    {
      "matches": ["https://*.hubspot.com/contacts/*/objects/*/views/*/list*"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["interceptor.js"],
      "matches": ["https://*.hubspot.com/*"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
